# Copy to .env for local development.
NUXT_SESSION_PASSWORD=change-me-to-a-random-32-character-secret
DATABASE_URL=./data/app.db

# Optional SMTP for password-reset emails. Without it, reset links are
# printed to the server console (fine for development).
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM="Slova <no-reply@example.com>"
